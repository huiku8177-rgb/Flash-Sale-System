<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flashsale.aiservice.mapper.ChatRecordMapper">

    <resultMap id="ChatRecordResultMap" type="com.flashsale.aiservice.domain.po.ChatRecordPO">
        <id property="id" column="id"/>
        <result property="sessionId" column="session_id"/>
        <result property="userId" column="user_id"/>
        <result property="productId" column="product_id"/>
        <result property="recordNo" column="record_no"/>
        <result property="question" column="question"/>
        <result property="questionCategory" column="question_category"/>
        <result property="answer" column="answer"/>
        <result property="answerPolicy" column="answer_policy"/>
        <result property="sourcesJson" column="sources_json"/>
        <result property="hitKnowledgeJson" column="hit_knowledge_json"/>
        <result property="confidence" column="confidence"/>
        <result property="fallbackReason" column="fallback_reason"/>
        <result property="auditSummary" column="audit_summary"/>
        <result property="modelName" column="model_name"/>
        <result property="latencyMs" column="latency_ms"/>
        <result property="estimatedTokens" column="estimated_tokens"/>
        <result property="createdAt" column="created_at"/>
        <result property="expireAt" column="expire_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id,
        session_id,
        user_id,
        product_id,
        record_no,
        question,
        question_category,
        answer,
        answer_policy,
        sources_json,
        hit_knowledge_json,
        confidence,
        fallback_reason,
        audit_summary,
        model_name,
        latency_ms,
        estimated_tokens,
        created_at,
        expire_at
    </sql>

    <insert id="insert" parameterType="com.flashsale.aiservice.domain.po.ChatRecordPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_record (
            session_id,
            user_id,
            product_id,
            record_no,
            question,
            question_category,
            answer,
            answer_policy,
            sources_json,
            hit_knowledge_json,
            confidence,
            fallback_reason,
            audit_summary,
            model_name,
            latency_ms,
            estimated_tokens,
            created_at,
            expire_at
        ) VALUES (
            #{sessionId},
            #{userId},
            #{productId},
            #{recordNo},
            #{question},
            #{questionCategory},
            #{answer},
            #{answerPolicy},
            #{sourcesJson},
            #{hitKnowledgeJson},
            #{confidence},
            #{fallbackReason},
            #{auditSummary},
            #{modelName},
            #{latencyMs},
            #{estimatedTokens},
            #{createdAt},
            #{expireAt}
        )
    </insert>

    <select id="nextRecordNo" resultType="int">
        SELECT COALESCE(MAX(record_no), 0) + 1
        FROM chat_record
        WHERE session_id = #{sessionId}
    </select>

    <select id="listBySessionId" resultMap="ChatRecordResultMap">
        SELECT *
        FROM (
            SELECT
            <include refid="BaseColumns"/>
            FROM chat_record
            WHERE session_id = #{sessionId}
            ORDER BY record_no DESC
            LIMIT #{limit}
        ) recent_records
        ORDER BY record_no ASC
    </select>

    <select id="listRecentBySessionId" resultMap="ChatRecordResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM chat_record
        WHERE session_id = #{sessionId}
        ORDER BY record_no DESC
        LIMIT #{limit}
    </select>

    <select id="countRecords" resultType="long">
        SELECT COUNT(1) FROM chat_record
    </select>

    <delete id="deleteExpired">
        DELETE FROM chat_record
        WHERE expire_at &lt; #{deadline}
    </delete>
</mapper>
