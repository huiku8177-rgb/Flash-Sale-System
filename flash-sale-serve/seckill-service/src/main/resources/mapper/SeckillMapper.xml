<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flashsale.seckillservice.mapper.SeckillMapper">

    <select id="getOrderByUserIdAndProductId"
            resultType="com.flashsale.seckillservice.domain.po.SeckillOrderPO">
        SELECT
            id,
            user_id,
            product_id,
            seckill_price,
            status,
            create_time
        FROM seckill_order
        WHERE user_id = #{userId}
          AND product_id = #{productId}
        LIMIT 1
    </select>

</mapper>
