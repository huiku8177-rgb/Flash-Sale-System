<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flashsale.seckillservice.mapper.ProductMapper">

    <resultMap id="ProductVOResultMap" type="com.flashsale.seckillservice.domain.vo.ProductVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="subtitle" column="subtitle"/>
        <result property="categoryId" column="category_id"/>
        <result property="price" column="price"/>
        <result property="marketPrice" column="market_price"/>
        <result property="stock" column="stock"/>
        <result property="status" column="status"/>
        <result property="mainImage" column="main_image"/>
        <result property="detail" column="detail"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="BaseProductColumns">
        id,
        name,
        subtitle,
        category_id,
        price,
        market_price,
        stock,
        status,
        main_image,
        detail,
        create_time,
        update_time
    </sql>

    <select id="listProducts" resultMap="ProductVOResultMap">
        SELECT
        <include refid="BaseProductColumns"/>
        FROM product
        <where>
            <if test="queryDTO != null and queryDTO.name != null and queryDTO.name != ''">
                AND name LIKE CONCAT('%', #{queryDTO.name}, '%')
            </if>
            <if test="queryDTO != null and queryDTO.status != null">
                AND status = #{queryDTO.status}
            </if>
            <if test="queryDTO != null and queryDTO.categoryId != null">
                AND category_id = #{queryDTO.categoryId}
            </if>
        </where>
        ORDER BY update_time DESC, id DESC
    </select>

    <select id="getProductDetail" resultMap="ProductVOResultMap">
        SELECT
        <include refid="BaseProductColumns"/>
        FROM product
        WHERE id = #{id}
    </select>

</mapper>
